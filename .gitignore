# ===================================================================
# A. Dependencies
# ===================================================================
# Ignore all node_modules folders in any subdirectory
**/node_modules

# ===================================================================
# B. Build & Output Files
# ===================================================================
# Next.js build output
**/out/
**/.next/

# General build output
**/build/
**/dist/

# ===================================================================
# C. Environment & Secret Files (CRITICAL)
# ===================================================================
# Ignore all .env files
.env
.env*
!/.env.example # (if you have one, don't ignore it)

# Ignore the backend service account key
travelmate-backend/serviceAccountKey.json

# ===================================================================
# D. Logs & Debug Files
# ===================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.tsbuildinfo

# ===================================================================
# E. IDE & System Files
# ===================================================================
# Editor directories
.vscode/
.idea/

# OS generated files
.DS_Store
Thumbs.db

# ===================================================================
# F. Misc
# ===================================================================
# Vercel deployment files
.vercel/

# TypeScript declaration files for Next.js
next-env.d.ts
*.pem